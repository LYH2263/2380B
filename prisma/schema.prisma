generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  username     String   @unique
  password     String
  avatar       String?
  bio          String?  @db.Text
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 积分与等级相关
  points       Int      @default(0)
  totalPoints  Int      @default(0)
  level        Int      @default(1)
  inviteCode   String   @unique
  nicknameColor String?
  avatarFrame  String?
  adFree       Boolean  @default(false)

  // 邮箱验证
  emailVerified  Boolean @default(false)
  verifyToken    String? @unique

  // 关联
  favorites       Favorite[]
  subscriptions   Subscription[]
  likes           Like[]
  comments        Comment[]
  ratings         Rating[]
  novels          Novel[]          @relation("AuthorNovels")
  readHistory     ReadHistory[]
  pointRecords    PointRecord[]
  checkIns        CheckIn[]
  achievements    UserAchievement[]
  ownedItems      UserItem[]
  sentInvitations Invitation[]    @relation("SentInvitations")
  receivedInvitation Invitation?  @relation("ReceivedInvitation")

  conversationsAsUser1 Conversation[] @relation("ConversationUser1")
  conversationsAsUser2 Conversation[] @relation("ConversationUser2")
  messages         Message[]
  notifications    Notification[]
  pushPreferences  PushPreference?
  webPushSubscriptions WebPushSubscription[]
  analyticsEvents  AnalyticsEvent[]
  readSessions     ChapterReadSession[]
  retentions       UserRetention[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// 小说模型
model Novel {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  cover       String?
  authorId    Int
  status      NovelStatus @default(ONGOING)
  tags        String[]
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  author        User       @relation("AuthorNovels", fields: [authorId], references: [id])
  chapters      Chapter[]
  favorites     Favorite[]
  subscriptions Subscription[]
  notifications Notification[]
  notificationBatches NotificationBatch[]
  likes         Like[]
  ratings       Rating[]
  readHistory   ReadHistory[]
  analyticsEvents AnalyticsEvent[]
  readSessions  ChapterReadSession[]

  @@map("novels")
}

enum NovelStatus {
  ONGOING
  COMPLETED
  HIATUS
}

// 章节模型
model Chapter {
  id        Int      @id @default(autoincrement())
  novelId   Int
  title     String
  content   String   @db.Text
  order     Int
  wordCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  novel         Novel         @relation(fields: [novelId], references: [id], onDelete: Cascade)
  comments      Comment[]
  notifications Notification[]
  notificationBatches NotificationBatch[]
  analyticsEvents AnalyticsEvent[]
  readSessions  ChapterReadSession[]

  @@unique([novelId, order])
  @@map("chapters")
}

// 评论模型（支持段落评论）
model Comment {
  id         Int      @id @default(autoincrement())
  userId     Int
  chapterId  Int
  content    String   @db.Text
  paragraph  Int?     // 段落索引，null 表示章节级评论
  parentId   Int?     // 父评论ID，用于回复
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 关联
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter  Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@map("comments")
}

// 收藏模型
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  novelId   Int
  createdAt DateTime @default(now())

  // 关联
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("favorites")
}

// 点赞模型
model Like {
  id        Int      @id @default(autoincrement())
  userId    Int
  novelId   Int
  createdAt DateTime @default(now())

  // 关联
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("likes")
}

// 评分模型
model Rating {
  id        Int      @id @default(autoincrement())
  userId    Int
  novelId   Int
  score     Int      // 1-5 分
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("ratings")
}

// 阅读历史
model ReadHistory {
  id            Int      @id @default(autoincrement())
  userId        Int
  novelId       Int
  lastChapterId Int?
  progress      Float    @default(0) // 0-100 百分比
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@map("read_history")
}

// 积分流水记录
enum PointSource {
  CHECKIN
  CHECKIN_BONUS
  CREATE_NOVEL
  PUBLISH_CHAPTER
  COMMENT
  RATING
  INVITE_USER
  NOVEL_FAVORITED
  NOVEL_LIKED
  REDEEM
  RETRO_CHECKIN
  SYSTEM
}

model PointRecord {
  id          Int         @id @default(autoincrement())
  userId      Int
  points      Int
  source      PointSource
  description String?
  createdAt   DateTime    @default(now())

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("point_records")
}

// 签到记录
model CheckIn {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime
  isRetro   Boolean  @default(false)
  bonus     Int      @default(0)
  createdAt DateTime @default(now())

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("check_ins")
}

// 成就定义
model Achievement {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String
  icon        String
  points      Int      @default(0)
  criteria    String   // JSON string for achievement criteria
  category    AchievementCategory @default(GENERAL)
  createdAt   DateTime @default(now())

  // 关联
  userAchievements UserAchievement[]

  @@map("achievements")
}

enum AchievementCategory {
  GENERAL
  CREATION
  READING
  SOCIAL
  SPECIAL
}

// 用户成就
model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        Int
  achievementId Int
  unlockedAt    DateTime @default(now())

  // 关联
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// 积分商城物品
model ShopItem {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  price       Int
  category    ItemCategory
  image       String?
  effectValue String? // JSON string for item effect (avatar frame id, color code, etc.)
  durationDays Int?   // null means permanent
  isActive    Boolean   @default(true)
  stock       Int?      // null means unlimited
  soldCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 关联
  userItems UserItem[]

  @@unique([name, category])
  @@map("shop_items")
}

enum ItemCategory {
  AVATAR_FRAME
  NICKNAME_COLOR
  AD_FREE
  BADGE
  OTHER
}

// 用户兑换/拥有的物品
model UserItem {
  id         Int       @id @default(autoincrement())
  userId     Int
  shopItemId Int
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  // 关联
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopItem ShopItem @relation(fields: [shopItemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_items")
}

// 用户邀请
model Invitation {
  id          Int      @id @default(autoincrement())
  inviterId   Int
  inviteeId   Int      @unique
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())

  // 关联
  inviter User @relation("SentInvitations", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User @relation("ReceivedInvitation", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([inviterId])
  @@map("invitations")
}

// 私信会话
model Conversation {
  id            Int       @id @default(autoincrement())
  user1Id       Int
  user2Id       Int
  lastMessageId Int?     @unique
  lastMessagePreview String? @db.VarChar(200)
  lastMessageAt DateTime?
  unreadCount1  Int       @default(0)
  unreadCount2  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  user1         User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2         User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  lastMessage   Message?  @relation("LastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)
  messages      Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("conversations")
}

// 私信消息
model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String       @db.Text
  readByReceiver Boolean      @default(false)
  createdAt      DateTime     @default(now())

  // 关联
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  lastMessageFor Conversation? @relation("LastMessage")

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

// 分析事件类型
enum AnalyticsEventType {
  PAGE_VIEW
  NOVEL_DETAIL_VIEW
  CHAPTER_START
  CHAPTER_COMPLETE
  USER_SIGNUP
  USER_LOGIN
}

// 通用分析事件表
model AnalyticsEvent {
  id         Int                @id @default(autoincrement())
  type       AnalyticsEventType
  userId     Int?
  deviceId   String?
  novelId    Int?
  chapterId  Int?
  path       String
  referrer   String?
  userAgent  String?
  ipAddress  String?
  properties Json?
  createdAt  DateTime           @default(now())

  // 关联
  user       User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  novel      Novel?             @relation(fields: [novelId], references: [id], onDelete: SetNull)
  chapter    Chapter?           @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([novelId, createdAt])
  @@index([chapterId, createdAt])
  @@index([deviceId, createdAt])
  @@map("analytics_events")
}

// 章节阅读会话表
model ChapterReadSession {
  id            Int      @id @default(autoincrement())
  userId        Int?
  deviceId      String
  novelId       Int
  chapterId     Int
  startTime     DateTime @default(now())
  endTime       DateTime?
  duration      Int      @default(0)
  totalParagraphs Int
  lastParagraph Int      @default(0)
  completionRate Float   @default(0)
  exitPoint     Int?
  isCompleted   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 关联
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  novel         Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter       Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([novelId, createdAt])
  @@index([chapterId, createdAt])
  @@index([deviceId, createdAt])
  @@map("chapter_read_sessions")
}

// 每日统计汇总表
model DailyStats {
  id              Int      @id @default(autoincrement())
  date            DateTime @unique
  pageViews       Int      @default(0)
  uniqueVisitors  Int      @default(0)
  activeUsers     Int      @default(0)
  newUsers        Int      @default(0)
  newNovels       Int      @default(0)
  newChapters     Int      @default(0)
  totalReadingTime Int     @default(0)
  avgReadingTime  Float    @default(0)
  completionRate  Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@map("daily_stats")
}

// 用户留存表
model UserRetention {
  id              Int      @id @default(autoincrement())
  cohortDate      DateTime
  userId          Int
  day0            Boolean  @default(true)
  day1            Boolean  @default(false)
  day7            Boolean  @default(false)
  day14           Boolean  @default(false)
  day30           Boolean  @default(false)
  lastActiveDate  DateTime

  // 关联
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortDate, userId])
  @@index([cohortDate])
  @@map("user_retention")
}

// ============================================
// 订阅与通知相关模型
// ============================================

// 通知类型枚举
enum NotificationType {
  NOVEL_UPDATE
  SYSTEM
  MESSAGE
  ACHIEVEMENT
}

// 通知状态枚举
enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

// 推送方式枚举
enum PushMethod {
  IN_APP
  EMAIL
  WEB_PUSH
}

// 推送频率枚举
enum PushFrequency {
  REALTIME
  DAILY_DIGEST
}

// 订阅模型 - 区分于收藏，订阅表示希望接收更新通知
model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  novelId   Int
  createdAt DateTime @default(now())

  // 关联
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
  @@index([userId])
  @@index([novelId])
  @@map("subscriptions")
}

// 通知模型
model Notification {
  id            Int                @id @default(autoincrement())
  userId        Int
  novelId       Int?
  chapterId     Int?
  type          NotificationType   @default(NOVEL_UPDATE)
  title         String
  content       String             @db.Text
  status        NotificationStatus @default(PENDING)
  read          Boolean            @default(false)
  pushMethods   PushMethod[]
  sentAt        DateTime?
  readAt        DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // 关联
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel   Novel?   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([novelId])
  @@index([status])
  @@index([type])
  @@index([read, userId])
  @@map("notifications")
}

// 推送偏好设置
model PushPreference {
  id                 Int             @id @default(autoincrement())
  userId             Int             @unique
  pushFrequency      PushFrequency   @default(REALTIME)
  enableInApp        Boolean         @default(true)
  enableEmail        Boolean         @default(false)
  enableWebPush      Boolean         @default(false)
  lastDigestSentAt   DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_preferences")
}

// 浏览器推送订阅
model WebPushSubscription {
  id            Int      @id @default(autoincrement())
  userId        Int
  endpoint      String   @unique
  p256dh        String
  auth          String
  userAgent     String?
  createdAt     DateTime @default(now())

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("web_push_subscriptions")
}

// 通知批量处理队列（用于大量订阅者时的异步处理）
model NotificationBatch {
  id            Int      @id @default(autoincrement())
  novelId       Int
  chapterId     Int
  totalCount    Int      @default(0)
  processedCount Int     @default(0)
  failedCount   Int      @default(0)
  status        BatchStatus @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  // 关联
  novel   Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("notification_batches")
}

enum BatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
